{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "short_name": "Regex Filters",
  "description": "__MSG_extensionDescription__",
  "version": "0.1.0",
  "default_locale": "en",
  "author": "Stephen Haptonstahl",
  "browser_specific_settings": {
    "gecko": {
      "id": "regex-filters@polimath.example",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "accountsRead",
    "messagesRead",
    "messagesMove",
    "messagesTags",
    "messagesUpdate",
    "messagesDelete",
    "storage"
  ],
  "background": {
    "scripts": ["background/background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
